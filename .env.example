# The application defaults to fake mode and needs no Azure resources.
APP_MODE=fake
CREDENTIAL_MODE=azure-cli

# Set these only to run against an existing Azure deployment from your workstation.
AZURE_OPENAI_ENDPOINT=https://<account>.openai.azure.com/
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-5-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_API_VERSION=preview
AZURE_OPENAI_EMBEDDING_API_VERSION=2024-10-21
COSMOS_ENDPOINT=https://<account>.documents.azure.com:443/
COSMOS_DATABASE=agentmemory
COSMOS_CONTAINER=memories
REDIS_HOST=<cache>.<region>.redis.azure.net
REDIS_PORT=10000
REDIS_USERNAME=<your-entra-object-id>
